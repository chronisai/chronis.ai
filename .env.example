# ── Chronis V2 — Environment Variables ──────────────────────────────────────
# Copy this to .env and fill in real values.
# Railway: set these in the Variables tab (never commit real values).

# ── Existing (migrated from V1) ───────────────────────────────────────────────
GEMINI_API_KEY=            # Gemini 1.5 Flash for video analysis (demo)
GROQ_API_KEY=              # Groq Llama 3.3 70B — LLM inference + Whisper STT
ELEVENLABS_API_KEY=        # Not used in V2 pipeline (kept for future)
RESEND_API_KEY=            # Transactional email (waitlist welcome, notify)
NOTIFY_EMAIL=              # Your email for new session notifications
ADMIN_SECRET=              # Admin panel access key — keep this strong
SUPABASE_URL=              # e.g. https://xyzxyz.supabase.co
SUPABASE_SERVICE_KEY=      # Service role key (not anon key) — full DB access
RAZORPAY_KEY_ID=           # rzp_live_... or rzp_test_...
RAZORPAY_KEY_SECRET=       # your Razorpay secret key
PAYMENT_AMOUNT_PAISE=      # amount in paise (default 10000 = ₹100)
SITE_URL=https://chronis.in

# ── V1 XTTS (HuggingFace Space — demo /api/speak endpoint) ───────────────────
XTTS_SPACE_URL=            # e.g. https://chronisai-chronis-tts.hf.space
XTTS_SECRET=               # Matches API_SECRET in your HF Space

# ── V2 New (live session pipeline) ───────────────────────────────────────────

# Simli — avatar rendering
# Get from: https://simli.com/dashboard
SIMLI_API_KEY=             # sk_simli_...

# Deepgram — streaming STT (Nova-2)
# Get from: https://deepgram.com — $200 free credit on signup
DEEPGRAM_API_KEY=          # ...

# Daily.co — WebRTC rooms with EC/NS/AGC
# Get from: https://www.daily.co/dashboard
# Free tier: 1,000 participant-minutes/month
# ⚠ TIGHT LIMIT: 50 users × 20 min = exactly the limit. Keep dev sessions < 5 min.
DAILY_API_KEY=             # ...

# Modal — XTTS v2 on GPU
# Get from: https://modal.com
# $30/mo free credit. A10G GPU: ~$0.90/hr.
# After deploying modal_app/xtts_server.py, grab the endpoint URL.
MODAL_XTTS_URL=            # e.g. https://your-modal-workspace--chronis-xtts-v2-fastapi-app.modal.run/synthesize

# ── Build order reminder ──────────────────────────────────────────────────────
# 1. modal deploy modal_app/xtts_server.py  → set MODAL_XTTS_URL
# 2. python smoke_tests/test_simli.py       → confirm clearBuffer/sendImmediate
# 3. python smoke_tests/test_xtts_latency.py → confirm first chunk < 700ms
# 4. python smoke_tests/test_audio_format.py → confirm resampler + VAD frames
# 5. uvicorn main_v2:app --port 8000        → start server
# 6. Run a live session and watch the logs
